# Local server
PORT=3000
NODE_ENV=development

# Supabase project URL (do not add /rest/v1)
SUPABASE_URL=https://qdgtfqfmdsrgbllwabvd.supabase.co
# Paste the secret/service-role key locally. Never commit the real value.
SUPABASE_SERVICE_ROLE_KEY=PASTE_YOUR_ROTATED_SECRET_KEY_HERE
SUPABASE_BUCKET=holobox-media

# Session security - use a random string of at least 32 characters
SESSION_SECRET=CHANGE_TO_A_LONG_RANDOM_VALUE
SESSION_COOKIE_NAME=hb_session
SESSION_MAX_AGE_SEC=1209600

# Created automatically only when no platform admin exists
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_PASSWORD=CHANGE_TO_A_STRONG_PASSWORD_8_CHARS_OR_MORE
ADMIN_INITIAL_NAME=TLC Admin

# Upload and device status
UPLOAD_MAX_BYTES=262144000
SIGNED_URL_TTL_SEC=3600
HEARTBEAT_WARNING_SEC=45
HEARTBEAT_OFFLINE_SEC=90
DEVICE_HEARTBEAT_INTERVAL_SEC=15
